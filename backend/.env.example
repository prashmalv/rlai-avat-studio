# LLM Provider
# Options: ollama | anthropic | bedrock
LLM_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# Bedrock (when LLM_PROVIDER=bedrock)
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# Avatar Provider API Keys
HEYGEN_API_KEY=your-heygen-key
DID_API_KEY=your-did-key
SIMLI_API_KEY=your-simli-key

# Voice Provider API Keys
ELEVENLABS_API_KEY=your-elevenlabs-key
SARVAM_API_KEY=your-sarvam-key

# App
DATABASE_URL=sqlite+aiosqlite:///./avataar_platform.db
UPLOADS_DIR=./uploads
SECRET_KEY=change-me-in-production
